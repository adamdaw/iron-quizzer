{
    "name": "iron-quizzer",
    "version": "0.0.0",
    "author": "Adam Daw",
    "bugs": "https://github.com/adamdaw/iron-quizzer/issues",
    "devDependencies": {
        "@lwc/jest-preset": "^19.6.0",
        "@rollup/plugin-replace": "^6.0.3",
        "@salesforce/eslint-config-lwc": "^4.1.2",
        "@wdio/cli": "^9.27.0",
        "@wdio/local-runner": "^9.27.0",
        "@wdio/mocha-framework": "^9.27.0",
        "@wdio/spec-reporter": "^9.27.0",
        "@web/dev-server": "^0.4.6",
        "geckodriver": "^6.1.0",
        "husky": "^9.1.7",
        "jest": "^29.7.0",
        "lint-staged": "^16.4.0",
        "lwc": "^9.1.3",
        "prettier": "^3.8.2",
        "rollup": "^4.60.1",
        "rollup-plugin-copy": "^3.5.0",
        "start-server-and-test": "^3.0.2",
        "utam": "^3.3.0",
        "wdio-geckodriver-service": "^5.0.2",
        "wdio-utam-service": "^3.3.0"
    },
    "overrides": {
        "axios": "^1.16.0",
        "basic-ftp": "^5.3.1",
        "edgedriver": "^6.1.2",
        "fast-xml-parser": "^5.7.3",
        "jsondiffpatch": "^0.7.3",
        "postcss": "^8.5.14",
        "serialize-javascript": "^7.0.5",
        "tar-fs": "^3.1.2",
        "ws": "^8.18.0"
    },
    "engines": {
        "node": ">=18.0.0"
    },
    "homepage": "https://github.com/adamdaw/iron-quizzer",
    "keywords": [
        "lwc"
    ],
    "license": "MIT",
    "lint-staged": {
        "**/*.{css,html,js,json,md,ts,yaml,yml}": [
            "prettier --write"
        ],
        "./src/**/*.js": [
            "eslint"
        ]
    },
    "repository": "adamdaw/iron-quizzer",
    "scripts": {
        "build": "rollup -c --environment BUILD:production",
        "build:development": "rollup -c",
        "lint": "eslint \"src/**/*.js\"",
        "prepare": "husky",
        "prettier": "prettier --write '**/*.{css,html,js,json,md,ts,yaml,yml}'",
        "prettier:verify": "prettier --list-different '**/*.{css,html,js,json,md,ts,yaml,yml}'",
        "serve": "wds --root-dir dist --no-open",
        "test:unit": "jest",
        "test:unit:coverage": "jest --coverage",
        "test:unit:debug": "jest --debug",
        "test:unit:watch": "jest --watch",
        "test:utam:compile": "utam -c utam.config.json",
        "pretest:ui": "npm run test:utam:compile",
        "test:ui": "start-server-and-test serve http://localhost:8000 wdio",
        "wdio": "wdio run wdio.conf.js",
        "watch": "rollup -c --watch"
    }
}
